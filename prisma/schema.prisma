generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  createdAt         DateTime           @default(now())
  role              Role               @default(STAFF)
  isActive          Boolean            @default(true)
  lat               Float?
  lng               Float?
  locationUpdatedAt DateTime?
  lastLeadAssignedAt DateTime?
  assignedCustomers  Customer[]         @relation("AssignedTo")
  createdCustomers   Customer[]         @relation("CreatedBy")
  verifiedCustomers  Customer[]         @relation("VerifiedBy")
  uploadedDocs       CustomerDocument[] @relation("UploadedBy")
  uploadedRecordings CallRecording[]    @relation("RecordingUploadedBy")
  pushSubscriptions  PushSubscription[]
  activities         CustomerActivity[]

  @@map("user")
}

model Customer {
  id             String             @id @default(uuid())
  name           String
  phone          String
  goldWeight     Float?
  loanAmount     Float?
  branch         String?
  status         Status             @default(WAITING)
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignedToId   String?
  createdById    String?
  photoUrl       String?
  assignedAt     DateTime?
  callStatus     CallStatus         @default(NOT_CALLED)
  firstContactAt DateTime?
  followUpDate   DateTime?
  followUpNotes  String?
  priority       Priority           @default(MEDIUM)
  responseTime   Int?
  interestRate   Float?
  isVerified     Boolean            @default(false)
  startDate      DateTime?
  verifiedAt     DateTime?
  verifiedById   String?
  assignedTo     User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy      User?              @relation("CreatedBy", fields: [createdById], references: [id])
  verifiedBy     User?              @relation("VerifiedBy", fields: [verifiedById], references: [id])
  documents      CustomerDocument[]
  recordings     CallRecording[]
  activities     CustomerActivity[]
  lastCalledAt   DateTime?

  @@index([status, assignedToId])
  @@index([createdAt])
  @@index([lastCalledAt])
  @@map("customer")
}

model CustomerActivity {
  id          String   @id @default(uuid())
  customerId  String
  userId      String?
  action      String   // e.g. "STATUS_CHANGE", "CALL_RECORDED", "DOC_UPLOAD", "ASSIGNMENT"
  details     String?  // e.g. "Moved from WAITING to PROCESSING"
  createdAt   DateTime @default(now())
  
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
  
  @@map("customer_activities")
}

model CallRecording {
  id          String   @id @default(uuid())
  customerId  String
  uploadedById String
  audioUrl    String
  label       String?
  durationSec Int?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy  User     @relation("RecordingUploadedBy", fields: [uploadedById], references: [id])

  @@map("call_recordings")
}

model CustomerDocument {
  id           String   @id @default(uuid())
  documentName String
  documentType String
  documentUrl  String
  uploadedAt   DateTime @default(now())
  customerId   String
  uploadedById String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("customer_documents")
}

enum Role {
  MANAGER
  STAFF
  SALESMAN
  MAINTENANCE
}

enum Status {
  WAITING
  PROCESSING
  ACCEPTED
  REJECTED
  DUE
  CLOSED
  FOLLOW_UP
  NO_RESPONSE
  VERIFIED
  CLOSE_REQUESTED
  MAINTENANCE
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum CallStatus {
  NOT_CALLED
  CALLED
  NOT_REACHABLE
  BUSY
  INTERESTED
}

model MetaLeadQueue {
  id          String   @id @default(uuid())
  leadgenId   String   @unique
  formId      String?
  pageId      String?
  createdAt   DateTime @default(now())
  isProcessed Boolean  @default(false)

  @@map("meta_lead_queue")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
