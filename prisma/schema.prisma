generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MANAGER
  STAFF
}

enum Status {
  WAITING
  PROCESSING
  ACCEPTED
  REJECTED
  DUE
  CLOSED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  // Relations
  assignedCustomers Customer[] @relation("AssignedTo")
  createdCustomers  Customer[] @relation("CreatedBy")
  uploadedDocs      CustomerDocument[] @relation("UploadedBy")

  @@map("user")
}

model Customer {
  id         String   @id @default(uuid())
  name       String
  phone      String
  goldWeight Float?
  loanAmount Float?
  branch     String?
  photoUrl   String?
  status     Status   @default(WAITING)
  dueDate    DateTime?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Foreign Keys
  assignedToId String?
  createdById  String?

  // Relations
  assignedTo User? @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User? @relation("CreatedBy", fields: [createdById], references: [id])
  documents  CustomerDocument[]

  @@map("customer")
}

model CustomerDocument {
  id           String   @id @default(uuid())
  documentName String
  documentType String
  documentUrl  String
  uploadedAt   DateTime @default(now())

  // Foreign Keys
  customerId   String
  uploadedById String

  // Relations
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("customer_documents")
}
