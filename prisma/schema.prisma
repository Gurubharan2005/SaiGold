generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String
  name              String
  createdAt         DateTime           @default(now())
  role              Role               @default(STAFF)
  isActive          Boolean            @default(true)
  lat               Float?
  lng               Float?
  locationUpdatedAt DateTime?
  assignedCustomers Customer[]         @relation("AssignedTo")
  createdCustomers  Customer[]         @relation("CreatedBy")
  verifiedCustomers Customer[]         @relation("VerifiedBy")
  uploadedDocs      CustomerDocument[] @relation("UploadedBy")

  @@map("user")
}

model Customer {
  id             String             @id @default(uuid())
  name           String
  phone          String
  goldWeight     Float?
  loanAmount     Float?
  branch         String?
  status         Status             @default(WAITING)
  dueDate        DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  assignedToId   String?
  createdById    String?
  photoUrl       String?
  assignedAt     DateTime?
  callStatus     CallStatus         @default(NOT_CALLED)
  firstContactAt DateTime?
  followUpDate   DateTime?
  followUpNotes  String?
  priority       Priority           @default(MEDIUM)
  responseTime   Int?
  interestRate   Float?
  isVerified     Boolean            @default(false)
  startDate      DateTime?
  verifiedAt     DateTime?
  verifiedById   String?
  assignedTo     User?              @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy      User?              @relation("CreatedBy", fields: [createdById], references: [id])
  verifiedBy     User?              @relation("VerifiedBy", fields: [verifiedById], references: [id])
  documents      CustomerDocument[]

  @@map("customer")
}

model CustomerDocument {
  id           String   @id @default(uuid())
  documentName String
  documentType String
  documentUrl  String
  uploadedAt   DateTime @default(now())
  customerId   String
  uploadedById String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("UploadedBy", fields: [uploadedById], references: [id])

  @@map("customer_documents")
}

enum Role {
  MANAGER
  STAFF
  SALESMAN
}

enum Status {
  WAITING
  PROCESSING
  ACCEPTED
  REJECTED
  DUE
  CLOSED
  FOLLOW_UP
  NO_RESPONSE
  VERIFIED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum CallStatus {
  NOT_CALLED
  CALLED
  NOT_REACHABLE
  BUSY
  INTERESTED
}
